---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import FlashcardsShell from "../components/FlashcardsShell.astro";
import PartDivider from "../components/PartDivider.astro";
import Card from "../components/Card.astro";
import GuideCard from "../components/GuideCard.astro";
import { PARTS, GUIDE_PART, optimizeBg, type OptimizedBg } from "../lib/parts";

const cards = (await getCollection("cards")).sort((a, b) => a.data.num - b.data.num);
const guide = (await getCollection("guide")).sort((a, b) =>
	parseInt(a.data.num.slice(1), 10) - parseInt(b.data.num.slice(1), 10)
);
const guideTotal = guide.length;

const bgByPartId: Record<string, OptimizedBg> = Object.fromEntries(
	await Promise.all(PARTS.map(async (p) => [p.id, await optimizeBg(p.bgImage)]))
);
const guideBg = await optimizeBg(GUIDE_PART.bgImage);

const parts = PARTS.map((part) => {
	const partCards = cards.filter((c) => c.data.num >= part.range[0] && c.data.num <= part.range[1]);
	const rangeLabel = `cards ${String(part.range[0]).padStart(2, "0")}–${String(part.range[1]).padStart(2, "0")}`;
	return { part, partCards, rangeLabel };
});
---
<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title="Flashcards · 身體智慧" description="Body Wisdom Cards by Dr Peggy — 64 bilingual flashcards plus an 8-part companion guide." />
	</head>
	<body class="flashcards-page">
		<Header />
		<FlashcardsShell>
			{parts.map(({ part, partCards, rangeLabel }, partIdx) => (
				<Fragment>
					<PartDivider
						roman={part.roman}
						nameEn={part.nameEn}
						nameZh={part.nameZh}
						subEn={part.subEn}
						subZh={part.subZh}
						rangeLabel={rangeLabel}
					/>
					{partCards.map((entry, cardIdx) => (
						<Card entry={entry} bg={bgByPartId[part.id]} eager={partIdx === 0 && cardIdx === 0} />
					))}
				</Fragment>
			))}

			<PartDivider
				roman={GUIDE_PART.roman}
				nameEn={GUIDE_PART.nameEn}
				nameZh={GUIDE_PART.nameZh}
				subEn={GUIDE_PART.subEn}
				subZh={GUIDE_PART.subZh}
				rangeLabel={`${guideTotal} pages`}
			/>
			{guide.map((entry) => <GuideCard entry={entry} total={guideTotal} bg={guideBg} />)}
		</FlashcardsShell>
		<script is:inline>
			(async function () {
				if (new URLSearchParams(location.search).get("print") !== "1") return;
				if (document.fonts?.ready) await document.fonts.ready;
				const bgImgs = Array.from(document.querySelectorAll("img.bg"));
				bgImgs.forEach((img) => { img.loading = "eager"; });
				await Promise.all(bgImgs.map((img) => img.complete
					? Promise.resolve()
					: new Promise((done) => { img.onload = img.onerror = () => done(); })));
				setTimeout(() => window.print(), 100);
			})();
		</script>
	</body>
</html>
