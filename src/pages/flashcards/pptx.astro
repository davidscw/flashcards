---
import { getCollection } from "astro:content";
import { PARTS, GUIDE_PART, partFor } from "../../lib/parts";
import CardFace from "../../components/flashcards/CardFace.astro";
import GuideFace from "../../components/flashcards/GuideFace.astro";
import "../../styles/flashcards-pptx.css";

const cards = (await getCollection("cards")).sort((a, b) => a.data.num - b.data.num);
const guide = (await getCollection("guide")).sort(
	(a, b) => parseInt(a.data.num.slice(1), 10) - parseInt(b.data.num.slice(1), 10),
);

type Slide =
	| { kind: "card-front" | "card-back"; card: (typeof cards)[number]["data"] }
	| { kind: "guide-front" | "guide-back"; entry: (typeof guide)[number]["data"] };

const slides: Slide[] = [];
for (const c of cards) {
	slides.push({ kind: "card-front", card: c.data });
	slides.push({ kind: "card-back", card: c.data });
}
for (const g of guide) {
	slides.push({ kind: "guide-front", entry: g.data });
	slides.push({ kind: "guide-back", entry: g.data });
}
const totalCards = "64";
const guideTotal = guide.length;
---
<!doctype html>
<html lang="zh-Hant">
<head>
	<meta charset="utf-8" />
	<title>Flashcards PPTX Export</title>
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
{slides.map((s, idx) => {
	if (s.kind === "card-front" || s.kind === "card-back") {
		const { card } = s;
		const part = partFor(card.num);
		const isFront = s.kind === "card-front";
		const screenLabel = `${card.num} ${card.conceptEn || card.titleEn} (${isFront ? "front" : "back"})`;
		return (
			<div class={`slide part-${part.id}`} data-slide-index={idx} data-screen-label={screenLabel}>
				<div class="bg" style={`background-image:url(${part.bgImage})`}></div>
				<div class="overlay-grad-l"></div>
				<div class="content">
					<div class="left">
						<div>
							<div class="eyebrow-row">
								<span class="theme-tag">{part.roman} · {isFront ? part.nameZh : part.nameEn}</span>
							</div>
							<div class="big-num"><b>{card.num}</b><span class="of">/ {totalCards}</span></div>
							<CardFace
								card={card}
								face={isFront ? "front" : "back"}
								area="left"
								variant="pptx"
								titleOverride={!isFront ? (card.titleEn || card.conceptEn) : undefined}
							/>
						</div>
						<div class="credit">Dr Peggy · Hong Kong</div>
					</div>
					<div class="right">
						<CardFace card={card} face={isFront ? "front" : "back"} area="right" variant="pptx" />
					</div>
				</div>
			</div>
		);
	}
	const { entry } = s;
	const isFront = s.kind === "guide-front";
	const screenLabel = `Guide ${entry.num} ${entry.titleEn} (${isFront ? "front" : "back"})`;
	const numSuffix = entry.num.replace(/^G/, "");
	return (
		<div class={`slide guide-${entry.num}`} data-slide-index={idx} data-screen-label={screenLabel}>
			<div class="bg" style={`background-image:url(${GUIDE_PART.bgImage})`}></div>
			<div class="overlay-grad-l"></div>
			<div class="content">
				<div class="left">
					<div>
						<div class="eyebrow-row">
							<span class="theme-tag">{isFront ? GUIDE_PART.nameZh : GUIDE_PART.nameEn}</span>
						</div>
						<div class="big-num"><b>{numSuffix}</b><span class="of">/ {guideTotal}</span></div>
						<GuideFace entry={entry} face={isFront ? "front" : "back"} area="left" variant="pptx" />
					</div>
					<div class="credit">Dr Peggy · Hong Kong</div>
				</div>
				<div class={"right" + (entry.kind === "list-dense" ? " dense" : "")}>
					<GuideFace entry={entry} face={isFront ? "front" : "back"} area="right" variant="pptx" />
				</div>
			</div>
		</div>
	);
})}
<script is:inline>
	(function () {
		const params = new URLSearchParams(location.search);
		const startRaw = params.get("s");
		const countRaw = params.get("c");
		if (startRaw === null && countRaw === null) return;
		const start = Math.max(0, parseInt(startRaw || "0", 10) || 0);
		const slideEls = document.querySelectorAll(".slide");
		const count = countRaw !== null ? parseInt(countRaw, 10) : slideEls.length;
		const end = start + (Number.isFinite(count) ? count : slideEls.length);
		slideEls.forEach((el, i) => {
			if (i < start || i >= end) (el).style.display = "none";
		});
	})();
</script>
<script is:inline>
	(async function () {
		if (new URLSearchParams(location.search).get("print") !== "1") return;
		if (document.fonts?.ready) await document.fonts.ready;
		const bgUrls = Array.from(document.querySelectorAll(".bg"))
			.map((el) => getComputedStyle(el).backgroundImage.match(/url\(["']?(.+?)["']?\)/)?.[1])
			.filter(Boolean);
		await Promise.all(bgUrls.map((src) => new Promise((done) => {
			const img = new Image();
			img.onload = img.onerror = () => done();
			img.src = src;
		})));
		setTimeout(() => window.print(), 100);
	})();
</script>
</body>
</html>
