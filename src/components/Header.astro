---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE_ZH, SITE_TITLE_EN } from '../consts';
---

<header class="site-header">
	<nav class="site-nav">
		<a class="brand" href="/" aria-label={SITE_TITLE_EN}>
			<span class="brand-mark" aria-hidden="true"></span>
			<span class="brand-text">
				<span class="i18n-zh">{SITE_TITLE_ZH}</span>
				<span class="i18n-en">{SITE_TITLE_EN}</span>
			</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">
				<span class="i18n-zh">首頁</span>
				<span class="i18n-en">Home</span>
			</HeaderLink>
			<HeaderLink href="/blog">
				<span class="i18n-zh">文章</span>
				<span class="i18n-en">Blog</span>
			</HeaderLink>
			<HeaderLink href="/about">
				<span class="i18n-zh">關於</span>
				<span class="i18n-en">About</span>
			</HeaderLink>
		</div>
		<button class="lang-pill" type="button" data-lang-toggle aria-label="Toggle language">
			<span class="lang-pill-inner">
				<span class="lang-opt i18n-zh">EN</span>
				<span class="lang-opt i18n-en">中</span>
			</span>
		</button>
	</nav>
</header>

<script>
	import "../scripts/lang-toggle";
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--bg-glass);
		backdrop-filter: saturate(160%) blur(14px);
		-webkit-backdrop-filter: saturate(160%) blur(14px);
		border-bottom: 1px solid var(--line);
	}
	.site-nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		color: var(--ink-muted);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: .18em;
		text-transform: uppercase;
		white-space: nowrap;
	}
	.brand:hover { color: var(--ink); }
	.brand-mark {
		width: 8px; height: 8px;
		border-radius: var(--r-pill);
		background: var(--accent);
		box-shadow: 0 0 0 3px rgba(207, 199, 182, 0.12);
	}
	.brand-text .i18n-zh {
		font-family: var(--font-serif-zh);
		font-size: 15px;
		letter-spacing: .04em;
		text-transform: none;
	}

	.nav-links {
		display: flex;
		gap: 4px;
		align-items: center;
	}

	.lang-pill {
		appearance: none;
		background: transparent;
		border: 1px solid var(--line-strong);
		color: var(--ink-muted);
		border-radius: var(--r-pill);
		padding: 6px 12px;
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .14em;
		transition: border-color var(--t-fast), color var(--t-fast), background var(--t-fast);
	}
	.lang-pill:hover { border-color: var(--line-active); color: var(--ink); background: rgba(255,255,255,0.02); }
	.lang-pill-inner { display: inline-flex; align-items: center; }
	.lang-opt { font-weight: 600; }

	@media (max-width: 720px) {
		.site-nav { padding: 0 16px; gap: 8px; }
		.brand-text { display: none; }
		.nav-links { gap: 0; }
	}
</style>
